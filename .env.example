# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
DEVWALLET_PRIVATE_KEY=your_base58_encoded_private_key_here

# PumpFun Token Configuration
PUMPFUN_TOKEN_ADDRESS=your_token_mint_address_here
PUMPFUN_BUY_AMOUNT_SOL=0.01

# Server Configuration (Render sets PORT automatically)
PORT=8080
NODE_ENV=production
